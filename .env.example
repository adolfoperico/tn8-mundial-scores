# Registrate gratis en https://football-data.org/client/register
# Copiá tu token acá y renombrá este archivo a .env
FOOTBALL_DATA_TOKEN=pegue_su_token_aqui

# Código de competición (por defecto WC = Mundial FIFA).
# Para probar con la Champions League: CL. Con La Liga: PD.
COMPETITION_CODE=WC

# Ruta donde escribir el JSON (por default acá al lado)
OUTPUT_PATH=./resultados.json
